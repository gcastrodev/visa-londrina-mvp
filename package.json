    "next": "14.2.3",
    "next-auth": "^4.24.7",
    "nodemailer": "^6.9.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.38",
    "prisma": "^5.13.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.9.3",
