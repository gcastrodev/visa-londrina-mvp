    "docker:down": "docker compose down",
    "docker:seed": "npm run db:seed",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
