# .env.example
# Copie para .env e preencha os valores reais
# NUNCA comite o .env com valores reais

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://visa:visa_secret@localhost:5432/visa_londrina"
POSTGRES_USER=visa
POSTGRES_PASSWORD=visa_secret

# ── NextAuth.js ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── Serviços internos ───────────────────────────────────────────────────────
IA_SERVICE_URL=http://localhost:8000
JAVA_SERVICE_URL=http://localhost:8080

# ── E-mail (SMTP) ───────────────────────────────────────────────────────────
EMAIL_FROM=noreply@visa.londrina.pr.gov.br
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
